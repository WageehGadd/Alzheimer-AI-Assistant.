# Alzheimer Assistant Backend Environment Configuration

# Application
APP_NAME=Alzheimer Assistant Backend
APP_VERSION=1.0.0

# Database Configuration
MONGO_URI=mongodb://localhost:27017/alzheimer_app

# AI Services
COHERE_API_KEY=your_cohere_api_key_here

# Voice/TTS Configuration
# Options: "edge", "openai", "elevenlabs"
TTS_ENGINE=edge

# OpenAI TTS (for advanced voice quality)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_TTS_VOICE=shimmer  # Options: alloy, echo, fable, onyx, nova, shimmer

# ElevenLabs TTS (premium option - not implemented yet)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Fallback Configuration
TTS_AUTO_FALLBACK=true  # Automatically fallback to Edge TTS if OpenAI fails
